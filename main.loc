module bits-py (*)

import bits
import root-py

instance Bits a where
  source Py from "bits.py"
    ( "morloc_and" as (.&.)
    , "morloc_or" as (.|.)
    , "morloc_xor" as (.^.)
    , "morloc_shiftl" as (<<)
    , "morloc_shiftr" as (>>)
    , "morloc_bnot" as bnot
    , "morloc_testBit" as testBit
    , "morloc_setBit" as setBit
    , "morloc_clearBit" as clearBit
    , "morloc_flipBit" as flipBit
    , "morloc_popcount" as popcount
    )
